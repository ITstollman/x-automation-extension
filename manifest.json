{
  "manifest_version": 3,
  "name": "Xlift",
  "version": "0.1.0",
  "description": "Grow your brand on X. Xlift manages your accounts, suggests topics, and helps you launch authentic replies.",
  "permissions": [
    "activeTab",
    "alarms",
    "scripting",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://www.x.com/*",
    "https://twitter.com/*",
    "https://www.twitter.com/*",
    "https://*.up.railway.app/*",
    "https://generativelanguage.googleapis.com/*",
    "http://localhost:3500/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "reload-extension": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Reload Xlift and refresh open X tabs"
    }
  },
  "action": {
    "default_title": "Xlift",
    "default_icon": {
      "16": "icons/logo.png",
      "48": "icons/logo.png",
      "128": "icons/logo.png"
    }
  },
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://www.x.com/*",
        "https://twitter.com/*",
        "https://www.twitter.com/*"
      ],
      "js": ["lib/api.js", "lib/x-account.js", "lib/executor.js", "sidepanel.js", "content-widget.js", "reply-suggestions.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/logo.png",
        "sidepanel.html",
        "sidepanel.css",
        "sidepanel.js"
      ],
      "matches": [
        "https://x.com/*",
        "https://www.x.com/*",
        "https://twitter.com/*",
        "https://www.twitter.com/*"
      ]
    }
  ]
}
